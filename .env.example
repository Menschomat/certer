# Environment configurations for cert-central

# Environment setting (production / development)
ENV=production

# ACME provider settings (letsencrypt / zerossl)
ACME_PROVIDER=letsencrypt

# External Account Binding (EAB) credentials (required for ZeroSSL or custom CAs requiring binding)
EAB_KID=
EAB_HMAC=

# DNS provider credentials for ACME DNS-01 challenges
# Provide only the variable corresponding to your selected provider:

# 1. Cloudflare API Token
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here

# 2. Hetzner API Key
HETZNER_API_KEY=your_hetzner_api_key_here

