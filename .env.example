# Environment configurations for certer

# 1. Daemon Environment & Ports
ENV=production
PORT=8080
CHALLENGE_PORT=5002

# 2. ACME Provider Settings (letsencrypt / zerossl)
ACME_EMAIL=admin@example.com
ACME_PROVIDER=letsencrypt

# Optional custom ACME Directory URL (uncomment to override automatic defaults)
# ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory

# External Account Binding (EAB) credentials (required for ZeroSSL or custom CAs requiring binding)
EAB_KID=
EAB_HMAC=

# 3. DNS-01 / HTTP-01 Challenge Solver Settings
# Choose challenge solver: cloudflare, hetzner, or leave blank to fall back to HTTP-01
DNS_PROVIDER=cloudflare

# Optional comma-separated list of custom recursive DNS resolvers (e.g. to bypass local resolver failures/caching)
# DNS_RESOLVERS=1.1.1.1:53,8.8.8.8:53

# DNS API provider credentials (required if DNS_PROVIDER is set):
# Cloudflare API Token
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here

# Hetzner API Token
HETZNER_API_TOKEN=your_hetzner_api_token_here

# 4. Storage & Renewals
CERT_STORAGE_DIR=./certs
RENEW_THRESHOLD_DAYS=30
CHECK_INTERVAL_HOURS=24
